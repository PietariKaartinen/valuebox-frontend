# Shopify Storefront API
# Your Shopify store domain (e.g., your-store.myshopify.com)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (public, safe to expose in client)
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-api-token

# Site URL (used for sitemap, robots.txt, and Open Graph metadata)
# Set this to your Vercel deployment URL or custom domain
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
